{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "tieu-diem-backend",
  "main": "src/index.ts",
  "compatibility_date": "2026-07-08",
  "compatibility_flags": ["nodejs_compat"],
  "observability": { "enabled": true },
  // Custom domain (zone your-domain.example.com must be on this Cloudflare account).
  // Wrangler provisions the Worker custom domain + DNS record on deploy.
  // Keep workers.dev URL alive as a fallback alongside the custom domain.
  "routes": [{ "pattern": "your-domain.example.com", "custom_domain": true }],
  "workers_dev": true,
  // AUTH_TOKEN is a Workers Secret: `wrangler secret put AUTH_TOKEN`.
  // Rotation: run secret put again with a new value, then update the client.
  "vars": {
    "APP_USER_ID": "owner",
    "APP_TIMEZONE": "Asia/Bangkok",
    "DOD_GATE_ENABLED": "true"
  },
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "tieu-diem-db",
      "database_id": "REPLACE_WITH_YOUR_D1_DATABASE_ID",
      "migrations_dir": "migrations"
    }
  ],
  // Static frontend host. run_worker_first=true so the Worker's explicit dispatch
  // (/api -> Hono, /mcp -> MCP, else -> ASSETS) always runs first (finding C2).
  "assets": {
    "directory": "./public",
    "binding": "ASSETS",
    "run_worker_first": true
  }
}
